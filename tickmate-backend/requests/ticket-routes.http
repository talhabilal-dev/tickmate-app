### TickMate backend ticket route tests
### Works with VS Code REST Client extension (.http files)
### Install: Huachao Mao -> REST Client
### Semantic search threshold is controlled by env: SIMILAR_TICKET_MIN_SCORE (default 0.75)

### Update this base URL to match how ticket routes are mounted in src/index.ts
### Example: http://localhost:3000/api/tickets
@baseUrl = http://localhost:3000/api/tickets

### Use a valid JWT from login
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiIxMiIsInJvbGUiOiJ1c2VyIiwiaXNBY3RpdmUiOnRydWUsImlhdCI6MTc3Mjc4MzUyOCwiZXhwIjoxNzcyODY5OTI4fQ.bHQMqymo9OITPvoHav6gEeZkTvxelU0yLdoSIm3xl3s

### IDs used by requests below
@ticketId = 5
@assignedUserId = 2

### -----------------------------
### 1) Find similar resolved public tickets (protected)
### Use this before creating a ticket
### -----------------------------
POST {{baseUrl}}/similar
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "title": "Login fails after password reset",
  "description": "User cannot login after resetting password. Gets invalid credentials every time.",
  "category": "Authentication",
  "limit": 5
}

### -----------------------------
### 2) Create ticket (protected)
### -----------------------------
POST {{baseUrl}}/
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "title": "Login fails after password reset",
  "description": "User cannot login after resetting password. Gets invalid credentials every time.",
  "category": "Authentication",
  "priority": "high",
  "deadline": "2026-03-10T12:00:00.000Z",
  "relatedSkills": ["nodejs", "jwt", "postgres"],
  "helpfulNotes": "Check reset-token invalidation and password hashing flow.",
  "isPublic": true
}

### -----------------------------
### 3) Get my tickets (protected)
### -----------------------------
GET {{baseUrl}}/
Authorization: Bearer {{authToken}}

### -----------------------------
### 4) Toggle ticket status to completed (protected)
### -----------------------------
PUT {{baseUrl}}/status/{{ticketId}}
Authorization: Bearer {{authToken}}

### -----------------------------
### 5) Get assigned tickets (protected)
### -----------------------------
GET {{baseUrl}}/get-assigned
Authorization: Bearer {{authToken}}

### -----------------------------
### 6) Add ticket reply (moderator/admin + assigned user)
### -----------------------------
PUT {{baseUrl}}/ticket-reply
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "ticketId": {{ticketId}},
  "message": "Investigating this now. Please share your latest error logs."
}

### -----------------------------
### 7) Get ticket summary for current user (protected)
### -----------------------------
GET {{baseUrl}}/tickets-summary
Authorization: Bearer {{authToken}}

### -----------------------------
### 8) Delete ticket (owner/admin)
### -----------------------------
DELETE {{baseUrl}}/delete-ticket
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "ticketId": {{ticketId}}
}

### -----------------------------
### 9) Edit ticket (owner/admin)
### -----------------------------
PUT {{baseUrl}}/edit-ticket
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "ticketId": {{ticketId}},
  "title": "Login still fails after password reset",
  "description": "Updated details: issue happens only on mobile app.",
  "category": "Authentication",
  "priority": "medium",
  "status": "in_progress",
  "assignedTo": {{assignedUserId}},
  "deadline": "2026-03-12T09:30:00.000Z",
  "helpfulNotes": "Re-check auth cookie domain and token parsing.",
  "relatedSkills": ["nodejs", "express", "mobile-auth"],
  "isPublic": false
}
